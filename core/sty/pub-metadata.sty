%% pub-metadata.sty — Unified PDF/A + hyperref metadata setup
%% Merges from cv.cls (PDF/A-1a, PDF/UA) and user-guide.cls (PDF/A-2b)
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{pub-metadata}[2026/02/17 Publications PDF Metadata]

\RequirePackage{etoolbox}

%% ── Document metadata macros ────────────────────────────────────────────
\def\pub@docTitle{}
\def\pub@docAuthor{}
\def\pub@docDate{\today}
\def\pub@docVersion{}
\def\pub@docKeywords{}
\def\pub@docSubject{}
\def\pub@docCopyright{}
\def\pub@docPublisher{}
\def\pub@docLanguage{en}

\newcommand{\docTitle}[1]{\def\pub@docTitle{#1}}
\newcommand{\docAuthor}[1]{\def\pub@docAuthor{#1}}
\newcommand{\docDate}[1]{\def\pub@docDate{#1}}
\newcommand{\docVersion}[1]{\def\pub@docVersion{#1}}
\newcommand{\docKeywords}[1]{\def\pub@docKeywords{#1}}
\newcommand{\docSubject}[1]{\def\pub@docSubject{#1}}
\newcommand{\docCopyright}[1]{\def\pub@docCopyright{#1}}
\newcommand{\docPublisher}[1]{\def\pub@docPublisher{#1}}
\newcommand{\docLanguage}[1]{\def\pub@docLanguage{#1}}

%% ── PDF/A compliance ────────────────────────────────────────────────────
%% Two paths, picked at preamble time:
%%
%%   1. **Modern path (Sprint 1+, preferred)**: the document author calls
%%      \DocumentMetadata{...} BEFORE \documentclass. The LaTeX kernel
%%      then handles PDF/A and PDF/UA-2 natively via the tagging
%%      project; pdfx is skipped to avoid double-engagement of PDF/A.
%%      Required for tagged PDF, PDF/UA-2, PDF/A-4, and WCAG-aligned
%%      output (EAA enforcement live since 28 Jun 2025).
%%
%%   2. **Legacy path**: no \DocumentMetadata — camera-ready falls back
%%      to pdfx with PDF/A-2u, which produces a valid but un-tagged
%%      PDF/A. Kept for backwards compatibility with documents that
%%      haven't migrated to \DocumentMetadata yet.
%%
%% Both paths still receive document metadata via \hypersetup at
%% \AtBeginDocument time.
\newif\ifpub@pdfa \pub@pdfafalse

%% Allow class to request PDF/A conformance level (legacy path only).
%% Modern path uses pdfstandard=a-4 (or a-2u) inside \DocumentMetadata.
\def\pub@pdfalevel{a-2u}
\newcommand{\setPdfALevel}[1]{\def\pub@pdfalevel{#1}}

\iffinalmode
  \pub@pdfatrue
\fi

%% Detect whether \DocumentMetadata{...} has been used. \IfDocumentMetadataTF
%% was added to the LaTeX kernel in 2022-06-01. We require LuaLaTeX with
%% TeX Live 2024+ (decision D3, 2026-05-23), so this is safe.
\providecommand\IfDocumentMetadataTF[2]{#2}

\ifpub@pdfa
  \IfDocumentMetadataTF{%
    %% Modern path: kernel owns PDF/A + UA. Just load hyperref.
    \PassOptionsToPackage{hidelinks}{hyperref}%
    \RequirePackage{hyperref}%
    \hypersetup{pdfborder={0 0 0}}%
  }{%
    %% Legacy path: pdfx owns PDF/A (no UA tagging).
    \PassOptionsToPackage{hidelinks}{hyperref}%
    \RequirePackage{silence}%
    \WarningFilter{pdfx}{Setting all color commands}%
    \RequirePackage[\pub@pdfalevel]{pdfx}%
  }%
\else
  %% Pass 'final' so hyperref never inherits the document-level draft flag.
  %% Do NOT set colorlinks here — individual classes set it in \AtBeginDocument.
  %% pdfborder={0 0 0} hides link boxes by default.
  \PassOptionsToPackage{final}{hyperref}
  \RequirePackage{hyperref}
  \hypersetup{pdfborder={0 0 0}}
\fi

%% ── Hyperref behavioural settings + metadata injection ─────────────────
\AtBeginDocument{%
  \hypersetup{
    pdftitle=\pub@docTitle,
    pdfauthor=\pub@docAuthor,
    pdfsubject=\pub@docSubject,
    pdfkeywords=\pub@docKeywords,
    pdfcreator={LaTeX with hyperref},
    pdfproducer={Publications Build System},
    pdflang=\pub@docLanguage,
    bookmarksopen=true,
    bookmarksnumbered=true,
    breaklinks=true,
    unicode=true
  }%
}

\endinput
