%% pub-typography.sty — Font + microtype configuration for Publications
%% Merges settings from cv.cls, faqs.cls, user-guide.cls, patent.cls, arxiv_style.sty
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{pub-typography}[2026/02/17 Publications Typography]

\RequirePackage[T1]{fontenc}
\RequirePackage[utf8]{inputenc}
\RequirePackage{lmodern}        % Latin Modern: provides bold typewriter + all font shapes

%% ── Options: sans (default) or serif ────────────────────────────────────
\newif\ifpub@serif \pub@seriffalse
\DeclareOption{sans}{\pub@seriffalse}
\DeclareOption{serif}{\pub@seriftrue}
\ProcessOptions\relax

\RequirePackage{iftex}

\ifpub@serif
  % Serif stack: Times --- for papers and patents
  \RequirePackage{times}
  \renewcommand{\rmdefault}{ptm}
  \renewcommand{\sfdefault}{phv}
\else
  % Sans-serif stack: Helvetica (substituted by Nimbus Sans L on
  % most TeX Live installations) --- for CVs, FAQs, guides. We use
  % helvet rather than Source Sans 3 / Source Sans Pro because under
  % LuaLaTeX both load via fontspec and produce CID Type 0C subsets;
  % some macOS print drivers convert these to PostScript incorrectly
  % and render garbled glyphs on paper, even though the on-screen
  % rendering is fine. Helvetica/Nimbus Sans L is loaded as a Type 1
  % PostScript font that round-trips through every print pipeline.
  \RequirePackage{helvet}
  \renewcommand{\familydefault}{\sfdefault}
  \renewcommand{\sfdefault}{phv}
\fi

%% ── Microtype ───────────────────────────────────────────────────────────
\RequirePackage[protrusion=true,expansion=true,verbose=silent,patch=none]{microtype}

\ifPDFTeX
  \microtypesetup{
      activate={true,nocompatibility},
      final,
      tracking=true,
      kerning=true,
      spacing=false,
      factor=1100
  }
\else
  \microtypesetup{
      activate={true,nocompatibility},
      final,
      tracking=true,
      kerning=false,
      spacing=false,
      factor=1100
  }
\fi

%% ── Golden ratio constants (from cv.cls) ────────────────────────────────
\newcommand{\goldenratio}{1.618}
\newcommand{\goldenratiom}{0.618}
\newcommand{\goldenratiosm}{0.382}
\newcommand{\goldenratioxs}{0.236}

\endinput
